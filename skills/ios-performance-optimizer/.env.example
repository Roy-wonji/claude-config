# Claude Agent SDK Environment Configuration
# Copy this file to .env and set your API key

# Required: Your Anthropic API key
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# Optional: OpenAI API key for real Codex comparison
# Get your API key from: https://platform.openai.com/api-keys
# If not provided, Claude will simulate Codex approach
OPENAI_API_KEY=your_openai_key_here

# Optional: Alternative API providers
# Amazon Bedrock (set to 1 to use Bedrock)
# CLAUDE_CODE_USE_BEDROCK=0

# Google Vertex AI (set to 1 to use Vertex AI)
# CLAUDE_CODE_USE_VERTEX=0

# Microsoft Azure AI Foundry (set to 1 to use Azure)
# CLAUDE_CODE_USE_FOUNDRY=0

# Agent Configuration
# Set the model to use (claude-4-6, claude-sonnet-4-6, claude-haiku-4-5)
# CLAUDE_MODEL=claude-sonnet-4-6

# Logging level (debug, info, warn, error)
LOG_LEVEL=info

# Performance optimization settings
# Enable detailed performance logging
PERFORMANCE_LOGGING=true

# iOS project root path (defaults to current directory)
# IOS_PROJECT_PATH=./

# TCA analysis depth (shallow, medium, deep)
TCA_ANALYSIS_DEPTH=medium

# SwiftUI optimization level (basic, standard, aggressive)
SWIFTUI_OPTIMIZATION=standard