{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash",
      "Bash(curl:*)",
      "Bash(docker compose:*)",
      "Bash(docker:*)",
      "Bash(git:*)",
      "Bash(jq:*)",
      "Bash(node:*)",
      "Bash(npm i)",
      "Bash(npm:*)",
      "Bash(npx eslint . --ext .ts)",
      "Bash(npx eslint src/ test/ --ext .ts --fix)",
      "Bash(npx eslint src/ test/ --ext .ts)",
      "Bash(npx:*)",
      "Bash(rm /Users/suhwonji/Desktop/SideProject/OnebiteTypescript/Section6/package-lock.json)",
      "Edit",
      "Glob",
      "Grep",
      "Read",
      "Skill(keybindings-help)",
      "Skill(keybindings-help:*)",
      "Write",
      "mcp__figma",
      "mcp__pencil"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Edit(.env)",
      "Edit(.env.*)"
    ],
    "additionalDirectories": [
      "/Users/suhwonji/Desktop/SideProject/OnebiteTypescript/Section6/src"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git -C \"$HOME/.claude\" pull --ff-only --quiet 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Syncing claude-config...",
            "async": true
          },
          {
            "type": "command",
            "command": "find .omc/state/sessions -mindepth 1 -maxdepth 1 -type d -mtime +7 -exec rm -rf {} + 2>/dev/null || true",
            "timeout": 15,
            "statusMessage": "오래된 .omc 세션 정리 중",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/context-engineering.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/block-dangerous.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/block-git-push.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "figma",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/block-figma-write.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/auto-format.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/type-check.sh",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/quality-gate.sh",
            "timeout": 120,
            "statusMessage": "Quality Gate · 정적 품질 게이트"
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "방금 종료된 서브에이전트의 결과($ARGUMENTS의 tool_response)가 CLAUDE.md/프로젝트 규칙을 지켰는지 판단하라. 점검: (1) 요청 범위를 벗어난 변경이 없는지, (2) 코드 변경 시 포맷·타입체크가 통과 가능한 상태인지, (3) 자기 작성물을 자기가 최종 승인하지 않았는지(리뷰/검증은 별도 패스여야 함), (4) 결과에 검증·근거가 제시됐는지. 위반이 명확하면 ok=false로, 무엇을 다시 검증·수정해야 하는지 한국어로 구체적으로 지적하라. 애매하면 ok=true.",
            "timeout": 30,
            "continueOnBlock": true,
            "statusMessage": "서브에이전트 규칙 준수 재검증"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/handoff-on-failure.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/test.sh",
            "asyncRewake": true,
            "timeout": 600,
            "statusMessage": "Test · 실행 중…",
            "rewakeSummary": "❌ 테스트 실패"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node ${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hud/omc-hud.mjs"
  },
  "enabledPlugins": {
    "agent-council@team-attention-plugins": true,
    "swift-lsp@claude-plugins-official": true,
    "gitlab@claude-plugins-official": false,
    "agent-sdk-dev@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "developer-kit-typescript@developer-kit": true,
    "oh-my-claudecode@omc": true,
    "superpowers@superpowers-dev": true,
    "frontend-design@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "apple-skills@roy-claude-config": true,
    "warp@claude-code-warp": true,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "omc": {
      "source": {
        "source": "git",
        "url": "https://github.com/Yeachan-Heo/oh-my-claudecode.git"
      }
    },
    "superpowers-dev": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers"
      }
    },
    "roy-claude-config": {
      "source": {
        "source": "github",
        "repo": "Roy-wonji/claude-config"
      }
    },
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-ansi",
  "fileCheckpointingEnabled": true,
  "todoFeatureEnabled": true,
  "teammateMode": "auto",
  "remoteControlAtStartup": true,
  "autoUploadSessions": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true
}